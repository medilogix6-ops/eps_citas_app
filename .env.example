# ─────────────────────────────────────────────
#  Copia este archivo como  .env  para desarrollo local
#  En Railway: configura estas variables en Settings → Variables
# ─────────────────────────────────────────────

SECRET_KEY=cambia-esta-clave-por-una-segura-y-larga

# Railway inyecta estas automáticamente cuando agregas el plugin MySQL:
MYSQL_HOST=containers-us-west-XXX.railway.app
MYSQL_PORT=7306
MYSQL_USER=root
MYSQL_PASSWORD=tu-password-de-railway
MYSQL_DATABASE=railway
